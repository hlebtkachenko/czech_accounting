# Normalize line endings to LF everywhere.
* text=auto eol=lf

*.py    text eol=lf
*.md    text eol=lf
*.json  text eol=lf
*.toml  text eol=lf
*.txt   text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf

# Binary assets.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.pdf binary
*.xlsx binary

# Documentation should not count toward language statistics.
docs/** linguist-documentation=true
